{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": ["python"]
    }
  },
  "deploy": {
    "startCommand": "python3 -m uvicorn api.main:app --host 0.0.0.0 --port ${PORT:-8080}",
    "restartPolicyType": "ON_FAILURE"
  }
}
